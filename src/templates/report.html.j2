<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>VAULT</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
  <link rel="stylesheet" href="style.css"/>
</head>
<body>
<header>
  <div class="logo">VAULT</div>
  <nav>
    {% for onto in data %}
      <a href="#onto-{{ onto.prefix }}">{{ onto.label }}</a>
    {% endfor %}
  </nav>
  <div class="header-meta">Generated: {{ generated_at }}</div>
</header>
<main>

  {# ── Summary strip ── #}
  <div class="summary-strip">
    {% for onto in data %}
    <div class="summary-card">
      <h3>{{ onto.label }}</h3>
      <div class="uri">{{ onto.uri }}</div>
      <div class="metrics">
        <div class="metric">
          <span class="metric-value">{{ onto.openalex.total_works }}</span>
          <span class="metric-label">Papers (OpenAlex)</span>
        </div>
        <div class="metric">
          <span class="metric-value">{{ onto.lov.inlinks }}</span>
          <span class="metric-label">Vocabularies (LOV)</span>
        </div>
        <div class="metric">
          <span class="metric-value">{{ onto.github.repos_count }}</span>
          <span class="metric-label">Repos (GitHub)</span>
        </div>
        <div class="metric">
          <span class="metric-value">{{ onto.opencitations.total_citations }}</span>
          <span class="metric-label">Citations (OpenCitations)</span>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>

  {# ── Per-ontology sections ── #}
  {% for onto in data %}
  <section class="onto-section" id="onto-{{ onto.prefix }}">

    <div class="section-header">
      <h2>{{ onto.label }}</h2>
      <span class="uri-badge">{{ onto.uri }}</span>
    </div>

    <div class="grid-2">

      {# LOV card #}
      <div class="card">
        <div class="card-header">
          <span class="source-tag lov-tag">LOV</span>
          <h3>Vocabulary reuse</h3>
        </div>
        <div class="card-stat">
          <span class="big-num">{{ onto.lov.inlinks }}</span>
          <span class="stat-label">vocabularies import, expand or specialize {{ onto.label }}</span>
        </div>
        <div class="card-detail">
          <ul class="compact-list">
            {% for vocab in onto.lov.using_vocabs[:10] %}
              <li><a href="{{ vocab.uri }}" target="_blank">{{ vocab.title or vocab.uri }}</a></li>
            {% else %}
              <li><em>None found</em></li>
            {% endfor %}
          </ul>
          {% if onto.lov.url %}
            <a class="styled-link lov-link" href="{{ onto.lov.url }}" target="_blank">View in LOV →</a>
          {% endif %}
        </div>
      </div>

      {# GitHub card #}
      <div class="card">
        <div class="card-header">
          <span class="source-tag github-tag">GitHub</span>
          <h3>Code usage</h3>
        </div>
        <div class="card-stat">
          <span class="big-num">{{ onto.github.repos_count }}</span>
          <span class="stat-label">public repositories reference {{ onto.label }} namespace</span>
        </div>
        <div class="card-detail">
          <ul class="compact-list">
            {% for repo in onto.github.repos[:8] %}
              <li><a href="https://github.com/{{ repo }}" target="_blank">{{ repo }}</a></li>
            {% else %}
              <li><em>None found</em></li>
            {% endfor %}
          </ul>
        </div>
      </div>
    
    </div>

    <div class="grid-2">

      {# OpenAlex card #}
      <div class="card">
        <div class="card-header">
          <span class="source-tag oax-tag">OpenAlex</span>
          <h3>Mentions in academic papers</h3>
        </div>
        <div class="card-stat">
          <span class="big-num">{{ onto.openalex.total_works }}</span>
          <span class="stat-label">papers mention {{ onto.label }} in titles, abstracts and/or texts</span>
        </div>
        <div class="card-detail">
          <canvas id="chart-{{ onto.prefix }}" height="120"></canvas>
        </div>
      </div>

      {# OpenCitations card #}
      <div class="card">
        <div class="card-header">
          <span class="source-tag oc-tag">OpenCitations</span>
          <h3>Citations to main publications</h3>
        </div>
        <div class="card-stat">
          <span class="big-num">{{ onto.opencitations.total_citations }}</span>
          <span class="stat-label">papers cite {{onto.label}} main publication(s)</span>
        </div>
        <div class="card-detail">
          <canvas id="chart-oc-{{ onto.prefix }}" height="120"></canvas>
        </div>
      </div>

    </div>{# end grid-2 #}

    {# OpenAlex table #}
    <div class="card card-table full-width">
      <div class="card-header">
        <span class="source-tag oax-tag">OpenAlex</span>
        <h3>Papers mentioning {{ onto.label }} in title, abstract and/or text</h3>
      </div>
      <table class="papers-table">
        <thead>
          <tr>
            <th>Title</th>
            <th>Authors</th>
            <th>Year</th>
            <th>Venue</th>
            <th>DOI</th>
          </tr>
        </thead>
        <tbody>
          {% for w in onto.openalex.top_works %}
          <tr>
            <td>{{ w.title }}</td>
            <td>{{ w.authors }}</td>
            <td>{{ w.year or '—' }}</td>
            <td>{{ w.source_name }}</td>
            <td><a class="styled-link" href="https://doi.org/{{ w.doi }}" target="_blank">{{ w.doi }}</a></td>
          </tr>
          {% else %}
          <tr><td colspan="3">No papers found</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {# OpenCitations table #}
    <div class="card card-table full-width">
      <div class="card-header">
        <span class="source-tag oc-tag">OpenCitations</span>
        <h3>Papers citing the main publications about {{ onto.label }}</h3>
      </div>
      <table class="papers-table">
        <thead>
          <tr>
            <th>Title</th>
            <th>Authors</th>
            <th>Year</th>
            <th>Venue</th>
            <th>DOI</th>
          </tr>
        </thead>
        <tbody>
          {% for w in onto.opencitations.citing_works[:8] %}
          <tr>
            <td>{{ w.title }}</td>
            <td>{{ w.authors }}</td>
            <td>{{ w.year }}</y }}</ttd>
            <td>{{ w.venue }}</y }}</ttd>
            <td><a class="styled-link" href="https://doi.org/{{ w.doi }}" target="_blank">{{ w.doi }}</a></td>
          </tr>
          {% else %}
          <tr><td colspan="3">No papers found</td></tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    {# Chart script #}
    <script>
    (function() {
      var ctx = document.getElementById('chart-{{ onto.prefix }}');
      if (!ctx) return;
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: {{ onto.openalex.by_year.keys() | list | sort | tojson }},
          datasets: [{
            label: 'Papers per year',
            data: {{ onto.openalex.by_year | dictsort | map(attribute=1) | list | tojson }},
            backgroundColor: '#2e37e94d',
            borderColor: '#232bc5',
            borderWidth: 1,
            borderRadius: 3,
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { display: false } },
          scales: {
            y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(255,255,255,0.05)' } },
            x: { grid: { display: false } }
          }
        }
      });
    })();

    (function() {
      var ctx = document.getElementById('chart-oc-{{ onto.prefix }}');
      if (!ctx) return;
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels: {{ onto.opencitations.by_year.keys() | list | sort | tojson }},
          datasets: [{
            label: 'Citations per year',
            data: {{ onto.opencitations.by_year | dictsort | map(attribute=1) | list | tojson }},
            backgroundColor: '#8561fa49',
            borderColor: '#7554e4',
            borderWidth: 1,
            borderRadius: 3,
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { display: false } },
          scales: {
            y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(255,255,255,0.05)' } },
            x: { grid: { display: false } }
          }
        }
      });
    })();
    </script>

  </section>
  {% endfor %}

</main>

<footer>
  <span>Sources: LOV · GitHub · OpenAlex</span>
  <span>Generated automatically via GitHub Actions · {{ generated_at }}</span>
</footer>

</body>
</html>